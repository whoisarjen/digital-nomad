{
  "name": "nomad-workspace",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "predev": "npx syncpack fix",
    "dev": "turbo run dev --filter=nomad -- --port 3000 & turbo run dev --filter=collector -- --port 3001",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "test": "turbo run test:run",
    "reinstall": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && rm -rf .turbo && npm i",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "husky": "^9.1.7",
    "syncpack": "^14.0.0",
    "turbo": "^2.8.3"
  },
  "packageManager": "npm@10.2.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
