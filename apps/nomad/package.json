{
  "name": "nomad",
  "version": "1.0.0",
  "description": "Compare 500+ cities by cost of living, weather, internet speed, safety, and more — built for digital nomads and remote workers.",
  "author": "Kamil Owczarek (https://github.com/whoisarjen)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/whoisarjen/digital-nomad.git"
  },
  "homepage": "https://github.com/whoisarjen/digital-nomad",
  "keywords": [
    "digital-nomad",
    "remote-work",
    "city-comparison",
    "cost-of-living",
    "nuxt",
    "vue",
    "typescript"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "nuxt prepare",
    "build": "nuxt build",
    "dev": "vercel env pull .env -y --environment=development && nuxt dev",
    "predev": "vercel env pull .env -y --environment=development",
    "dev:worktree": "nuxt dev",
    "dev:prod": "vercel env pull .env -y --environment=production && nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@nomad/db": "0.0.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@nuxt/image": "^1.10.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/sitemap": "^7.6.0",
    "@nuxtjs/tailwindcss": "^6.13.2",
    "@sidebase/nuxt-auth": "^1.2.0",
    "@tanstack/vue-query": "^5.69.0",
    "@vueuse/components": "^13.0.0",
    "@vueuse/core": "^13.0.0",
    "@vueuse/nuxt": "^13.0.0",
    "lodash": "^4.17.21",
    "next-auth": "^4.21.1",
    "nuxt": "^3.16.0",
    "nuxt-lucide-icons": "^1.0.5",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.16",
    "typescript": "^5.8.2",
    "vue-tsc": "^2.0.7"
  }
}
