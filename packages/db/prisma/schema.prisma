generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Level {
  LOW
  MIDDLE
  HIGH
}

model QualityIndex {
  citySlug String @id
  city     City   @relation(fields: [citySlug], references: [slug])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  slug                       String
  safetyIndex                Decimal?
  climateIndex               Decimal?
  pollutionIndex             Decimal?
  purchasingPowerIndex       Decimal?
  healthCareIndex            Decimal?
  costOfLivingIndex          Decimal?
  propertyPriceToIncomeRatio Decimal?
  trafficCommuteTimeIndex    Decimal?
  isNumberData               Boolean  @default(true)

  climate Json?

  @@map("Numbeo")
}

enum Region {
  Europe
  Asia
  LatinAmerica
  NorthAmerica
  MiddleEast
  Africa
  Oceania
  Antarctica
}

model Country {
  slug      String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  name                 String
  nameChinese          String
  code                 String
  region               Region
  internetSpeed        Int @default(0)
  internetSpeedRanking Int @default(0)
  englishProficiency   Int @default(0)
  plugTypes            String?
  voltage              Int?
  frequency            Int?

  cities City[]
}

model City {
  slug      String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  name         String
  countrySlug  String
  country      Country  @relation(fields: [countrySlug], references: [slug])
  population   Int
  temperatureC Decimal @db.Decimal(4, 1)
  latitude     Decimal @db.Decimal(9, 6)
  longitude    Decimal @db.Decimal(9, 6)

  nameChinese    String
  airQualityNow  Int
  airQuality     Float?
  stateCode      String?
  stateChinese   String?
  state          String?

  internetSpeedCity        Int
  internetSpeedCityRanking Int

  airQualityScore    Int
  airQualityNowScore Decimal @db.Decimal
  humidity           String

  costForNomadInUsd  Decimal @db.Decimal
  costForExpatInUsd  Decimal @db.Decimal
  costForLocalInUsd  Decimal @db.Decimal
  costForFamilyInUsd Decimal @db.Decimal

  safety                Level?
  climate               Level?
  pollution             Level?
  purchasingPower       Level?
  healthCare            Level?
  costOfLiving          Level?
  propertyPriceToIncome Level?
  trafficCommuteTime    Level?

  isWeather2024Collected Boolean @default(false)

  weathers     Weather[]      @relation("cityWeather")
  monthSummary MonthSummary[] @relation("cityMonthSummary")

  imageId  Int?
  image    Image?
  qualityIndexId String?   @map("numbeoId")
  qualityIndex   QualityIndex?

  articles  ArticleCityMap[]
  favorites Favorite[]
}

model Weather {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  date                     DateTime
  weatherCode              Int?
  apparentTemperatureMax   Decimal?
  rainSum                  Decimal?
  windGusts10mMax          Decimal?
  snowfallSum              Decimal?
  windDirection10mDominant Decimal?
  daylightDuration         Decimal?
  apparentTemperatureMin   Decimal?
  temperature2mMax         Decimal?
  temperature2mMin         Decimal?
  apparentTemperatureMean  Decimal?
  sunshineDuration         Decimal?
  precipitationHours       Decimal?
  shortwaveRadiationSum    Decimal?
  windSpeed10mMax          Decimal?
  precipitationSum         Decimal?
  temperature2mMean        Decimal?

  citySlug String
  city     City   @relation("cityWeather", fields: [citySlug], references: [slug], onDelete: Cascade)

  @@unique([citySlug, date])
}

enum WeatherIcon {
  SUN
  CLOUDY
  WIND
  RAIN
  SNOW
  NULL
}

model MonthSummary {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  month                    String      @db.VarChar(2)
  weatherCode              Int
  apparentTemperatureMax   Decimal
  rainSum                  Decimal
  windGusts10mMax          Decimal
  snowfallSum              Decimal
  windDirection10mDominant Decimal
  daylightDuration         Decimal
  apparentTemperatureMin   Decimal
  temperature2mMax         Decimal
  temperature2mMin         Decimal
  apparentTemperatureMean  Decimal
  sunshineDuration         Decimal
  precipitationHours       Decimal
  shortwaveRadiationSum    Decimal
  windSpeed10mMax          Decimal
  precipitationSum         Decimal
  temperature2mMean        Decimal
  weatherIcon              WeatherIcon @default(NULL)

  popularity            Int      @default(0)
  region                Region
  population            Int?
  internetSpeedCity     Int?
  totalScore            Int      @db.SmallInt
  costForNomadInUsd     Decimal? @db.Decimal
  safety                Level?
  climate               Level?
  pollution             Level?
  purchasingPower       Level?
  healthCare            Level?
  costOfLiving          Level?
  propertyPriceToIncome Level?
  trafficCommuteTime    Level?

  citySlug String
  city     City   @relation("cityMonthSummary", fields: [citySlug], references: [slug], onDelete: Cascade)

  @@unique([citySlug, month])
  @@index([citySlug, month])
}

model Image {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  width            Int
  height           Int
  url              String  @unique
  blurHash         String?
  downloadLocation String
  ownerName        String
  ownerUsername    String?

  citySlug String? @unique
  city     City?   @relation(fields: [citySlug], references: [slug])
}

model Article {
  slug        String   @id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  publishedAt DateTime?
  isPublished Boolean  @default(false)

  titleEn     String
  excerptEn   String
  contentEn   String
  metaTitleEn String?
  metaDescEn  String?

  titlePl     String
  excerptPl   String
  contentPl   String
  metaTitlePl String?
  metaDescPl  String?

  titleEs     String   @default("")
  excerptEs   String   @default("")
  contentEs   String   @default("")
  metaTitleEs String?
  metaDescEs  String?

  titleDe     String   @default("")
  excerptDe   String   @default("")
  contentDe   String   @default("")
  metaTitleDe String?
  metaDescDe  String?

  titlePt     String   @default("")
  excerptPt   String   @default("")
  contentPt   String   @default("")
  metaTitlePt String?
  metaDescPt  String?

  titleFr     String   @default("")
  excerptFr   String   @default("")
  contentFr   String   @default("")
  metaTitleFr String?
  metaDescFr  String?

  titleKo     String   @default("")
  excerptKo   String   @default("")
  contentKo   String   @default("")
  metaTitleKo String?
  metaDescKo  String?

  titleAr     String   @default("")
  excerptAr   String   @default("")
  contentAr   String   @default("")
  metaTitleAr String?
  metaDescAr  String?

  titleTr     String   @default("")
  excerptTr   String   @default("")
  contentTr   String   @default("")
  metaTitleTr String?
  metaDescTr  String?

  titleJa     String   @default("")
  excerptJa   String   @default("")
  contentJa   String   @default("")
  metaTitleJa String?
  metaDescJa  String?

  titleIt     String   @default("")
  excerptIt   String   @default("")
  contentIt   String   @default("")
  metaTitleIt String?
  metaDescIt  String?

  featuredImageUrl           String?
  featuredImageAlt           String?
  featuredImageOwnerName     String?
  featuredImageOwnerUsername String?
  readingTimeMinutes         Int     @default(5)

  faqs Json?

  cities ArticleCityMap[]

  @@index([isPublished, publishedAt])
}

model ArticleCityMap {
  articleSlug String
  article     Article @relation(fields: [articleSlug], references: [slug], onDelete: Cascade)
  citySlug    String
  city        City    @relation(fields: [citySlug], references: [slug], onDelete: Cascade)
  isPrimary   Boolean @default(false)

  @@id([articleSlug, citySlug])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  referralCode  String    @unique @default(cuid())
  referredBy    String?
  number        Int       @default(autoincrement())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  accounts      Account[]
  sessions      Session[]
  votes         Vote[]
  favorites     Favorite[]

  @@index([email])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Feature {
  id          String   @id @default(cuid())
  name        String
  description String
  status      String   @default("researching")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  votes       Vote[]
}

model Vote {
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  featureId String
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, featureId])
}

model Favorite {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  citySlug  String
  city      City     @relation(fields: [citySlug], references: [slug], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, citySlug])
  @@index([userId])
}
